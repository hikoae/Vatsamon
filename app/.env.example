# ──────────────────────────────────────────────────────────────
# Config Firebase per Vatsamon GO (login + salvataggio cloud).
# Copia questo file in `app/.env.local` e incolla i valori del tuo
# progetto Firebase (vedi FIREBASE_SETUP.md, Passo 2 e 5).
#
# Senza questi valori l'app gira in "modalità locale" (solo questo
# dispositivo, senza login): nessun crash, ma niente cloud.
# ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
